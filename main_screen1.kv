#:import dp kivy.metrics.dp

<MainScreen>:
    canvas.before:
        Rectangle:
            source: 'wpp3.png'
            size: self.size
            pos: self.pos
    
    BoxLayout:
        orientation: 'vertical'
        # Ubah padding & spacing ke dp
        padding: dp(20)
        spacing: dp(10)
        
        # Bagian atas untuk teks selamat datang
        BoxLayout:
            size_hint_y: 0.2
            # Padding atas diubah ke dp
            padding: [0, dp(20), 0, 0]
            
            Label:
                id: main_label
                text: 'Salam kenal, hm\nSekarang kenalan sama\nteman - teman Joy yuk!'
                font_size: '20sp'  # sp sudah benar untuk font
                color: 0.4, 0.2, 0.5, 1
                bold: True
                # PENTING: Pengurangan width juga harus pakai dp
                text_size: self.width - dp(40), None
                halign: 'left'
                valign: 'top'
                size_hint: 0.85, None
                # Tinggi label diubah ke dp
                height: dp(100)
                pos_hint: {'x': 0.05, 'top': 0.95}
        
        # Area tengah (kosong untuk gambar karakter)
        Label:
            text: ''
            size_hint_y: 0.7
        
        # Tombol Next di bawah kanan
        # ===== NEXT BUTTON (BOTTOM) =====
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            # Ukuran container tombol diubah ke dp
            size: dp(110), dp(45)
            # pos_hint center_x akan bekerja, tapi y mungkin diabaikan di dalam BoxLayout (itu normal)
            pos_hint: {'center_x': 0.85, 'y': 0.03}
                        
            Button:
                text: 'Next'
                font_size: '15sp'
                bold: True
                size_hint: 1, 1
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_press: root.go_to_next_screen()
                
                canvas.before:
                    Color:
                        rgba: 0.85, 0.4, 0.85, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        # Radius sudut tombol diubah ke dp
                        radius: [dp(20)]