<CurhatScreen>:
    canvas.before:
        Rectangle:
            source: 'wpp4.png'
            size: self.size
            pos: self.pos
    
    BoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(15)
        
        # Label "Journalling Page"
        Label:
            text: 'Journalling Page'
            font_size: sp(14)
            color: 0.4, 0.2, 0.5, 1
            size_hint_y: None
            height: dp(30)
            halign: 'left'
            valign: 'top'
            text_size: self.size
            padding: [dp(10), dp(5)]
        
        # Tombol back
        BoxLayout:
            size_hint_y: None
            height: dp(40)
            padding: [0, 0, 0, dp(5)]
            
            Button:
                text: '<'
                font_size: sp(32)
                bold: True
                color: 0.4, 0.2, 0.5, 1
                background_normal: ''
                background_color: 0, 0, 0, 0
                size_hint_x: 0.15
                on_press: root.go_back()
            
            Label:
                text: ''
                size_hint_x: 0.85
        
        # Greeting
        Label:
            id: greeting_label
            text: 'Hello, (nama)!'
            font_size: sp(18)
            bold: True
            color: 0.4, 0.2, 0.5, 1
            size_hint_y: None
            height: dp(35)
            halign: 'left'
            valign: 'middle'
            text_size: self.size
            padding: [dp(15), 0]
        
        # ScrollView untuk konten yang bisa di-scroll
        ScrollView:
            do_scroll_x: False
            do_scroll_y: True
            
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: dp(15)
                padding: [0, 0, 0, dp(10)]
                
                # Karakter Image dengan background rounded berwarna
                FloatLayout:
                    size_hint_y: None
                    height: dp(150)
                    
                    # Background dengan warna yang bisa berubah
                    canvas.before:
                        Color:
                            rgba: root.character_bg_color
                        RoundedRectangle:
                            size: self.width * 0.9, self.height * 0.95
                            pos: self.x + self.width * 0.05, self.y + self.height * 0.025
                            radius: [dp(20)]
                    
                    # Gambar karakter
                    Image:
                        id: character_image
                        source: 'sad.png'
                        size_hint: None, None
                        size: dp(120), dp(120)
                        center_x: self.parent.center_x
                        center_y: self.parent.center_y
                        allow_stretch: True
                        keep_ratio: True
                
                # Text "kamu gpp?"
                Label:
                    text: 'Kamu gpp?'
                    font_size: sp(16)
                    color: 0.4, 0.2, 0.5, 1
                    size_hint_y: None
                    height: dp(30)
                    halign: 'center'
                    valign: 'middle'
                
                # Box putih untuk input curhat
                FloatLayout:
                    size_hint_y: None
                    height: dp(200)
                    
                    # Background putih rounded
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 1
                        RoundedRectangle:
                            size: self.width * 0.9, dp(200)
                            pos: self.x + self.width * 0.05, self.y
                            radius: [dp(15)]
                    
                    # TextInput untuk curhat
                    TextInput:
                        id: curhat_input
                        hint_text: 'Ceritakan perasaanmu disini...'
                        hint_text_color: 0.5, 0.5, 0.5, 1
                        font_size: sp(14)
                        multiline: True
                        background_color: 0, 0, 0, 0
                        foreground_color: 0, 0, 0, 1
                        cursor_color: 0.5, 0, 0.5, 1
                        size_hint: 0.85, None
                        height: dp(180)
                        pos_hint: {'center_x': 0.5, 'center_y': 0.5}
                        padding: [dp(15), dp(15)]
                        do_wrap: True
        
        # Box untuk tombol Save dan Next (FIXED di bawah)
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(10)
            padding: [dp(30), 0, dp(30), 0]
            
            # Tombol Save
            Button:
                text: 'Save'
                font_size: sp(16)
                bold: True
                color: 1, 1, 1, 1
                background_normal: ''
                background_color: 0, 0, 0, 0
                size_hint_x: 0.48
                
                canvas.before:
                    Color:
                        rgba: 0.8, 0.4, 0.8, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [dp(20)]
                
                on_press: root.save_curhat()
            
            # Tombol Next
            Button:
                text: 'Next'
                font_size: sp(16)
                bold: True
                color: 1, 1, 1, 1
                background_normal: ''
                background_color: 0, 0, 0, 0
                size_hint_x: 0.48
                
                canvas.before:
                    Color:
                        rgba: 0.5, 0.7, 1, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [dp(20)]
                
                on_press: root.go_to_history()