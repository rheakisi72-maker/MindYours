#:import dp kivy.metrics.dp

<InputNameScreen>:
    canvas.before:
        Rectangle:
            source: 'wpp2.png'
            pos: self.pos
            size: self.size
    
    FloatLayout:
        # ===== BUBBLE CHAT (TOP) =====
        BoxLayout:
            orientation: 'vertical'
            size_hint: 0.7, None
            # Ubah tinggi statis menjadi dp
            height: dp(180)
            pos_hint: {'right': 0.95, 'top': 0.92}
            # Ubah padding menjadi dp
            padding: [dp(20), dp(15), dp(20), dp(15)]
            
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 0.95
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    # Ubah radius menjadi dp
                    radius: [dp(20), dp(20), dp(20), dp(5)]
            
            Label:
                text: 'Hiii, Selamat datang di aplikasi MindYours. Sebelum mulai, kita kenalan dulu yah. Nama aku Joy, Si Ceria. Kalo kamu?'
                font_size: '15sp'  # sp untuk teks (sudah benar)
                color: 0.4, 0.2, 0.5, 1
                halign: 'center'
                valign: 'middle'
                size_hint: 1, 1
                text_size: self.size
        
        # ===== NAME INPUT (MIDDLE) =====
        BoxLayout:
            orientation: 'vertical'
            size_hint: 0.85, None
            # Ubah tinggi menjadi dp
            height: dp(50)
            pos_hint: {'center_x': 0.5, 'y': 0.25}
            padding: [dp(5), 0, dp(5), 0]
            
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    size: self.size
                    pos: self.pos
                    radius: [dp(25)]
            
            TextInput:
                id: name_input
                hint_text: 'Masukkan nama'
                hint_text_color: 0.6, 0.6, 0.6, 1
                font_size: '18sp'
                multiline: False
                size_hint: 1, 1
                background_normal: ''
                background_color: 0, 0, 0, 0
                foreground_color: 0, 0, 0, 1
                cursor_color: 0.6, 0.3, 0.7, 1
                # Padding textinput juga perlu dp
                padding: [dp(20), dp(12), dp(20), dp(12)]
        
        # ===== NEXT BUTTON (BOTTOM) =====
        BoxLayout:
            orientation: 'vertical'
            size_hint: None, None
            # Ukuran tombol fix diubah ke dp
            size: dp(140), dp(55)
            pos_hint: {'center_x': 0.5, 'y': 0.15}
            
            Button:
                text: 'Next'
                font_size: '18sp'
                bold: True
                size_hint: 1, 1
                background_normal: ''
                background_color: 0, 0, 0, 0
                color: 1, 1, 1, 1
                on_press: root.save_and_next()
                
                canvas.before:
                    Color:
                        rgba: 0.7, 0.3, 0.7, 1
                    RoundedRectangle:
                        size: self.size
                        pos: self.pos
                        radius: [dp(27)]